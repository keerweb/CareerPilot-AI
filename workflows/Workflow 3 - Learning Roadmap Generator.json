        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const student = $('Get row(s) in sheet').first().json;\nconst ai = $('Message a model').first().json.content.parts[0].text;\n\nconst html = `\n<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\">\n<title>CareerPilot AI Report</title>\n\n<style>\n\nbody{\nfont-family:Arial;\nbackground:#f4f7fb;\npadding:40px;\n}\n\n.container{\nbackground:white;\npadding:40px;\nborder-radius:12px;\nbox-shadow:0px 0px 15px rgba(0,0,0,.1);\n}\n\nh1{\ncolor:#2563eb;\n}\n\nh2{\nmargin-top:30px;\ncolor:#444;\n}\n\n</style>\n\n</head>\n\n<body>\n\n<div class=\"container\">\n\n<h1>CareerPilot AI Report</h1>\n\n<h2>Student Details</h2>\n\n<p><b>Name:</b> ${student.Name}</p>\n<p><b>Email:</b> ${student.Email}</p>\n<p><b>College:</b> ${student.College}</p>\n<p><b>Degree:</b> ${student.Degree}</p>\n<p><b>Career Goal:</b> ${student.CareerGoal}</p>\n\n<hr>\n\n<h2>AI Recommendation</h2>\n\n<p>${ai.replace(/\\n/g,\"<br>\")}</p>\n\n</div>\n\n</body>\n\n</html>\n`;\n\nreturn {\n  json: {\n    html\n  }\n};"
      },
