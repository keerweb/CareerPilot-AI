        "messages": {
          "values": [
            {
              "content": "=You are an expert AI Career Mentor.\n\nCreate a detailed 6-month learning roadmap for this student.\n\nStudent Details:\n\nName: {{$json[\"Name\"]}}\nDegree: {{$json[\"Degree\"]}}\nSkills: {{$json[\"Skills\"]}}\nInterests: {{$json[\"Interests\"]}}\nCareer Goal: {{$json[\"CareerGoal\"]}}\n\nReturn the result in Markdown.\n\nInclude:\n\n# Career Goal\n\n# Monthly Roadmap\n\nMonth 1\nMonth 2\nMonth 3\nMonth 4\nMonth 5\nMonth 6\n\n# Certifications\n\n# Project Ideas\n\n# Books\n\n# YouTube Channels\n\n# Internship Preparation\n\n# Daily Routine"
            }
          ]
        },
        "builtInTools": {},
        "options": {}
      },
